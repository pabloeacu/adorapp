# Copy this file to .env.local and fill in the values.
#
# These are read by Vite at build time (any var prefixed with VITE_ is exposed to the client).
# The anon key is intentionally public — the security boundary is RLS + edge functions, not the key.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# IMPORTANT: do NOT add SUPABASE_SERVICE_ROLE_KEY here.
# The service role key lives only in Supabase Edge Function secrets, never in the client bundle.
